{
  "name": "aprs-tracker",
  "productName": "APRSaR Tracker",
  "version": "6.7.0",
  "description": "Full-featured SAR & APRS toolkit for ham radio operators",
  "main": "src/loader.js",
  "author": {
    "name": "914 Communications",
    "email": "admin@914communications.com"
  },
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:all": "electron-builder --win --x64 --ia32"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "bytenode": "^1.6.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "co.914communications.aprs-tracker",
    "productName": "APRSaR Tracker",
    "copyright": "Copyright \u00a9 2026 W7CTY / 914 Communications",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/loader.js",
      "src/main.jsc",
      "src/preload.js",
      "node_modules/bytenode/**/*"
    ],
    "extraResources": [
      {
        "from": "build/",
        "to": "build/",
        "filter": [
          "icon.ico",
          "icon.png",
          "ICON_NOTE.txt",
          "aprs-tracker.html.enc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "914 Communications"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "APRSaR Tracker",
      "deleteAppDataOnUninstall": false,
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp"
    },
    "publish": {
      "provider": "github",
      "owner": "W7CTY",
      "repo": "aprs-tracker-electron"
    },
    "linux": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "HamRadio",
      "synopsis": "APRSaR Tracker - Ham Radio & SAR Toolkit",
      "description": "Ham Radio & Search and Rescue tracking and tools application"
    }
  }
}